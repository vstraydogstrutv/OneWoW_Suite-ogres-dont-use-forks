# Handle line endings automatically for all files; default to LF
* text=auto eol=lf

# Explicitly mark Lua files as text
*.lua text eol=lf
*.luacheckrc text eol=lf linguist-language=Lua

# Documentation and metadata
*.md text eol=lf
LICENSE text eol=lf
README text eol=lf
.gitignore text eol=lf

# Cursor/VS Code workspace settings and snippets
.vscode/*.json text eol=lf
*.code-snippets text eol=lf

# Binary files (ensure they aren't corrupted)
*.png binary
*.jpg binary
*.tga binary
*.ico binary
*.ogg binary
*.mp3 binary
*.ttf binary
*.otf binary
*.luac binary
